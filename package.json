{
  "name": "plango-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "prestart": "node ./scripts/generate-environment.mjs --development",
    "start": "ng serve",
    "mock:api": "json-server --watch backend/db.json --port 3000",
    "prebuild": "node ./scripts/generate-environment.mjs",
    "build": "ng build",
    "prewatch": "node ./scripts/generate-environment.mjs --development",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.3",
  "dependencies": {
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@hugeicons/angular": "^1.0.7",
    "@hugeicons/core-free-icons": "^4.0.0",
    "@mapbox/polyline": "^1.2.1",
    "@ngrx/signals": "^21.1.0",
    "@types/aos": "^3.0.7",
    "@types/mapbox__polyline": "^1.0.5",
    "aos": "^2.3.4",
    "firebase": "^12.14.0",
    "flowbite": "^4.0.1",
    "maplibre-gl": "^5.22.0",
    "rxjs": "~7.8.0",
    "socket.io-client": "^4.8.3",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.1",
    "@angular/cli": "^21.1.1",
    "@angular/compiler-cli": "^21.1.0",
    "@tailwindcss/postcss": "^4.1.12",
    "json-server": "^1.0.0-beta.15",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2"
  }
}
